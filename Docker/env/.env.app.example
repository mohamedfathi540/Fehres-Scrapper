# =============================================================================
# Fehres — Application Configuration
# =============================================================================
# Copy this file to .env.app and fill in your own values.
#   cp .env.app.example .env.app
# =============================================================================

# ── App Metadata ─────────────────────────────────────────────────────────────
APP_NAME="Fehres"
APP_VERSION="0.1"

# ── File Processing ──────────────────────────────────────────────────────────
# Allowed MIME types for file upload
FILE_ALLOWED_TYPES=["text/plain", "application/pdf", "text/markdown", "text/x-markdown", "application/json", "text/csv", "application/vnd.openxmlformats-officedocument.wordprocessingml.document", "application/octet-stream"]
# Maximum file size in MB
FILE_MAX_SIZE=10
# Default chunk size in characters for file processing
FILE_DEFAULT_CHUNK_SIZE=512000

# ── PostgreSQL Database ──────────────────────────────────────────────────────
# These MUST match the values in .env.postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_HOST=pgvector
POSTGRES_PORT=5432
POSTGRES_MAIN_DB=minirag

# ── LLM Provider Configuration ──────────────────────────────────────────────
# Choose your generation and embedding backends.
# Options: OPENAI | GEMINI | COHERE | HUGGINGFACE | OLLAMA
GENRATION_BACKEND=OPENAI
EMBEDDING_BACKEND=OPENAI

# ── API Keys (fill in the ones you need) ─────────────────────────────────────
# OpenAI / OpenAI-compatible (e.g. Ollama via OpenAI-compat endpoint)
OPENAI_API_KEY=sk-your-openai-api-key-here
# Optional: override base URL for OpenAI-compatible servers (e.g. Ollama, LM Studio)
# OPENAI_BASE_URL=http://host.docker.internal:11434/v1
# Timeout in seconds for OpenAI API requests (increase for slow models)
OPENAI_REQUEST_TIMEOUT=120.0

# Google Gemini
# GEMINI_API_KEY=your-gemini-api-key-here
# GEMINI_API_VERSION=v1beta

# Cohere
# COHERE_API_KEY=your-cohere-api-key-here

# HuggingFace (for Inference API)
# HUGGINGFACE_API_KEY=hf_your-huggingface-token-here

# Ollama (local models — no API key needed)
# OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Model Selection ──────────────────────────────────────────────────────────
# List of available model IDs (for UI dropdowns)
GENRATION_MODEL_ID_LITERAL=["gpt-4o-mini", "gpt-4o", "gpt-3.5-turbo"]
EMBEDDING_MODEL_ID_LITERAL=["text-embedding-3-small", "text-embedding-3-large"]

# Active model IDs
GENRATION_MODEL_ID=gpt-4o-mini
EMBEDDING_MODEL_ID=text-embedding-3-small
# Embedding vector dimensions (must match the model's output size)
EMBEDDING_SIZE=1536

# ── Generation Parameters ────────────────────────────────────────────────────
# Max input characters sent to the LLM
INPUT_DEFUALT_MAX_CHARACTERS=768
# Max tokens the LLM can generate in a response
GENRATED_DEFUALT_MAX_OUTPUT_TOKENS=8196
# Temperature: 0.0 = deterministic, 1.0 = creative
GENRATION_DEFUALT_TEMPERATURE=0.1

# ── Vector Database ──────────────────────────────────────────────────────────
# Options: PGVECTOR | QDRANT
VECTORDB_BACKEND=PGVECTOR
VECTORDB_PATH=qdrant_DB
VECTORDB_DISTANCE_METHOD=cosine
# Minimum vectors before creating an index (PGVECTOR only)
VECTORDB_PGVEC_INDEX_THRESHOLD=4
VECTORDB_BACKEND_LITERAL=["QDRANT", "PGVECTOR"]

# ── Language Settings ────────────────────────────────────────────────────────
# Language for system prompts and default responses
PRIMARY_LANGUAGE=en
DEFUALT_LANGUAGE=en

# ── Learning Books (Educational Corpus) ──────────────────────────────────────
# Chunk size and overlap for learning book processing
LEARNING_BOOKS_CHUNK_SIZE=2000
LEARNING_BOOKS_OVERLAP_SIZE=200

# Optional: JSON mapping of filename to domain for chunk metadata
# Example: {"statistics.pdf": "statistics", "ml-intro.pdf": "ml"}
# BOOK_DOMAIN_MAPPING='{}'

# ── Hybrid Search (Dense + BM25) ────────────────────────────────────────────
# Enable hybrid search combining dense vectors and BM25 sparse retrieval
HYBRID_SEARCH_ENABLED=true
# Alpha blending: 0.0 = only BM25, 1.0 = only dense vectors
HYBRID_SEARCH_ALPHA=0.6
# Directory for BM25 index persistence (default: SRC/data/bm25)
# BM25_INDEX_DIR=

# ── Documentation Processing ────────────────────────────────────────────────
# Chunk size and overlap for scraped documentation
DOC_CHUNK_SIZE=1000
DOC_OVERLAP_SIZE=200
# Default project ID for single-project setups
DEFAULT_PROJECT_ID=1

# ── Web Scraping Configuration ───────────────────────────────────────────────
# Maximum number of pages to scrape from a single site
SCRAPING_MAX_PAGES=1000
# Delay in seconds between page requests (rate limiting)
SCRAPING_RATE_LIMIT=0.5
# User-Agent header for HTTP requests
SCRAPING_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/120.0.0.0 Safari/537.36
# Timeout in seconds for page loads
SCRAPING_TIMEOUT=120
# Batch size for embedding during scraping
SCRAPING_EMBED_BATCH_SIZE=50
# Embed chunks during scraping (1) or after (0)
SCRAPING_EMBED_DURING=0
# Log debug info for the first scraped URL (html_len, extracted_len, snippet)
SCRAPING_DEBUG=0
# Use Playwright headless Chromium for JS-rendered docs (1=yes, 0=use HTTP requests)
# If enabled, run: uv run playwright install chromium
SCRAPING_USE_BROWSER=1
# Number of concurrent pages to scrape (only when SCRAPING_USE_BROWSER=0)
SCRAPING_CONCURRENCY=1
# Respect robots.txt (0=respect, 1=ignore — use with care)
SCRAPING_IGNORE_ROBOTS=0
# Automatically index scraped content into vector DB
SCRAPING_AUTO_INDEX=1
