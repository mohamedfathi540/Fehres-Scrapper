# =============================================================================
# Fehres — PostgreSQL Exporter Configuration
# =============================================================================
# Copy this file to .env.postgres-exporter and update credentials.
#   cp .env.postgres-exporter.example .env.postgres-exporter
#
# IMPORTANT: Credentials must match the values in .env.postgres.
# =============================================================================

DATA_SOURCE_URI=pgvector:5432/postgres?sslmode=disable
DATA_SOURCE_USER=postgres
DATA_SOURCE_PASS=postgres
DATA_SOURCE_DB=minirag
