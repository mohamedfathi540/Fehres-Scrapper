# =============================================================================
# Fehres — Cloudflare Tunnel Configuration
# =============================================================================
# Copy this file to .env.cloudflared and add your tunnel token.
#   cp .env.cloudflared.example .env.cloudflared
#
# This service is OPTIONAL. It allows you to expose the app to the internet
# without port forwarding by routing traffic through Cloudflare's network.
#
# To get a token:
#   1. Sign up at https://dash.cloudflare.com (free)
#   2. Go to Zero Trust > Networks > Tunnels
#   3. Create a tunnel and copy the token
#   4. Configure Public Hostname → Service: HTTP://nginx:80
# =============================================================================

TUNNEL_TOKEN=your-cloudflare-tunnel-token-here
