# =============================================================================
# Fehres — PostgreSQL Configuration
# =============================================================================
# Copy this file to .env.postgres and update the credentials.
#   cp .env.postgres.example .env.postgres
#
# IMPORTANT: POSTGRES_USER, POSTGRES_PASSWORD, and POSTGRES_DB must match
# the values in .env.app (POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_MAIN_DB).
# =============================================================================

POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=minirag
